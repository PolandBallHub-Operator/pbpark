<script type="module">
  document.addEventListener('DOMContentLoaded', () => {
    const menuBtn = document.getElementById('menuBtn');
    const navDrawer = document.getElementById('navDrawer');
    const scrim = document.getElementById('scrim');
    const themeToggleBtn = document.getElementById('themeToggleBtn');
    const themeIcon = document.getElementById('themeIcon');
    const root = document.documentElement;
    const sourceColorInput = document.getElementById('source-color');

    // 1. ドロワーメニュー開閉ロジック
    const openDrawer = () => {
      navDrawer.opened = true;
      scrim.classList.add('show');
    };

    const closeDrawer = () => {
      navDrawer.opened = false;
      scrim.classList.remove('show');
    };

    // メニューボタンクリックでドロワーを開く
    menuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      openDrawer();
    });

    // スクリムクリックでドロワーを閉じる
    scrim.addEventListener('click', closeDrawer);

    // ナビゲーションリンククリックでドロワーを閉じる
    const linkItems = document.querySelectorAll('.link-item');
    linkItems.forEach(item => {
      item.addEventListener('click', closeDrawer);
    });

    // 2. ダークモード管理ロジック
    const updateThemeUI = (isDark) => {
      if (isDark) {
        root.classList.add('dark-mode');
        themeToggleBtn.label = "ライトモードにする";
        if (themeIcon) themeIcon.textContent = "light_mode";
      } else {
        root.classList.remove('dark-mode');
        themeToggleBtn.label = "ダークモードにする";
        if (themeIcon) themeIcon.textContent = "dark_mode";
      }
    };

    // 初期テーマの判定（ローカルストレージ or OS設定）
    const savedTheme = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDarkMode = savedTheme === 'dark' || (!savedTheme && prefersDark);
    
    updateThemeUI(isDarkMode);

    // テーマ切り替えボタンのイベント
    themeToggleBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const currentDark = root.classList.contains('dark-mode');
      const nextDark = !currentDark;
      updateThemeUI(nextDark);
      localStorage.setItem('theme', nextDark ? 'dark' : 'light');
    });

    // 3. カラーパレット連携（簡易実装）
    if (sourceColorInput) {
      sourceColorInput.addEventListener('input', (e) => {
        const color = e.target.value;
        root.style.setProperty('--md-sys-color-primary', color);
      });
    }
  });
</script>
