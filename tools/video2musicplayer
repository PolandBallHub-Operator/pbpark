        // --- PTZ適用のコア関数 ---
        function applyPtz(ptz) {
            currentPtz = { ...currentPtz, ...ptz };

            const root = document.documentElement;
            root.style.setProperty('--accent-primary', currentPtz.accentColor);
            root.style.setProperty('--accent-active', adjustColorBrightness(currentPtz.accentColor, -15));
            root.style.setProperty('--ptz-card-radius', `${currentPtz.cardRadius}px`);
            root.style.setProperty('--ptz-slider-height', `${currentPtz.sliderHeight}px`);
            root.style.setProperty('--ptz-toggle-width', `${currentPtz.toggleWidth}px`);
            root.style.setProperty('--ptz-toggle-height', `${currentPtz.toggleHeight}px`);
            root.style.setProperty('--ptz-toggle-knob-radius', isNaN(currentPtz.toggleKnobRadius) ? currentPtz.toggleKnobRadius : `${currentPtz.toggleKnobRadius}%`);
            root.style.setProperty('--ptz-toggle-knob-width', `${currentPtz.toggleKnobWidth}px`);
            
            root.style.setProperty('--bg-base', document.body.classList.contains('dark-mode') ? currentPtz.bgDark : currentPtz.bgLight);

            document.getElementById('current-theme-badge').textContent = currentPtz.themeName || "PTZ Config";
            ptzCodeArea.value = JSON.stringify(currentPtz, null, 2);
        }

        function adjustColorBrightness(hex, percent) {
            let R = parseInt(hex.substring(1, 3), 16);
            let G = parseInt(hex.substring(3, 5), 16);
            let B = parseInt(hex.substring(5, 7), 16);
            R = parseInt(R * (100 + percent) / 100);
            G = parseInt(G * (100 + percent) / 100);
            B = parseInt(B * (100 + percent) / 100);
            R = (R < 255) ? R : 255; G = (G < 255) ? G : 255; B = (B < 255) ? B : 255;
            const rHex = ((R.toString(16).length == 1) ? "0" + R.toString(16) : R.toString(16));
            const gHex = ((G.toString(16).length == 1) ? "0" + G.toString(16) : G.toString(16));
            const bHex = ((B.toString(16).length == 1) ? "0" + B.toString(16) : B.toString(16));
            return "#" + rHex + gHex + bHex;
        }

