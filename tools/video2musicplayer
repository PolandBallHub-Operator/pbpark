<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no">
    <title>FranceBall Background Media Engine</title>

    <!-- Google Fonts & Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">

    <style>
        /* デフォルトテーマ */
        :root {
            --accent-primary: #3381FF;
            --accent-active: #1A5FCC;
            
            /* PTZ 規格初期値 */
            --ptz-theme-name: "France Blue Theme";
            --ptz-card-radius: 24px;
            --ptz-slider-height: 16px;
            --ptz-toggle-width: 54px;
            --ptz-toggle-height: 30px;
            --ptz-toggle-knob-radius: 50%;
            --ptz-toggle-knob-width: 22px;
            --ptz-blur-intensity: 0px;

            /* Light Mode ベースカラー */
            --bg-base: #F7F7F7;
            --glass-bg: #FFFFFF;
            --text-main: #000000;
            --text-sub: #666666;
            --bg-secondary: #EEEEEE;
            --nav-bg: #FFFFFF;
            --nav-icon-active: #000000;
            
            --m3-easing: cubic-bezier(0.32, 0.72, 0, 1);
            --transition-smooth: 0.35s var(--m3-easing);
            --card-padding: 24px;
        }

        /* ダークモード */
        .dark-mode {
            --bg-base: #121212;
            --glass-bg: #1E1E1E;
            --text-main: #FFFFFF;
            --text-sub: #A1A1A6;
            --bg-secondary: #2C2C2E;
            --nav-bg: #1E1E1E;
            --nav-icon-active: #FFFFFF;
        }

        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', 'Noto Sans JP', sans-serif;
            background-color: var(--bg-base);
            color: var(--text-main);
            transition: background-color var(--transition-smooth), color var(--transition-smooth);
            overflow: hidden;
            height: 100vh;
            width: 100vw;
        }

        /* アプリ全体のコンテナ */
        #app-viewport {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
        }

        /* ヘッダー */
        header {
            height: 64px;
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--glass-bg);
            transition: background-color var(--transition-smooth);
            position: relative;
            flex-shrink: 0;
            z-index: 10;
        }
        .logo {
            font-weight: 700;
            font-size: 18px;
            letter-spacing: -0.5px;
            color: var(--text-main);
            text-align: center;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .logo img {
            width: 24px;
            height: 24px;
        }
        .theme-toggle {
            position: absolute;
            right: 24px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: none;
            background: var(--bg-secondary);
            color: var(--text-main);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background var(--transition-smooth), transform 0.2s;
        }
        .theme-toggle:active {
            transform: scale(0.9);
        }

        /* メインコンテンツ */
        main {
            flex-grow: 1;
            overflow-y: auto;
            padding: 24px 20px 100px;
            max-width: 720px;
            width: 100%;
            margin: 0 auto;
            -webkit-overflow-scrolling: touch;
        }

        /* フラットソリッドカード */
        .glass-card {
            background: var(--glass-bg);
            border-radius: var(--ptz-card-radius);
            padding: var(--card-padding);
            margin-bottom: 20px;
            box-shadow: none !important;
            border: none !important;
            transition: background-color var(--transition-smooth), border-radius var(--transition-smooth);
        }

        h2 { 
            font-size: 18px; 
            margin-top: 0; 
            margin-bottom: 12px;
            font-weight: 700; 
            letter-spacing: -0.3px;
        }
        p {
            font-size: 13.5px;
            line-height: 1.5;
            margin-top: 0;
            margin-bottom: 16px;
            color: var(--text-sub);
        }

        /* リストコンポーネント */
        .custom-list {
            display: flex;
            flex-direction: column;
            gap: 2px;
            margin-bottom: 16px;
        }
        .list-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 4px;
            border-bottom: 1px solid var(--bg-secondary);
        }
        .list-item:last-child {
            border-bottom: none;
        }
        .list-item-title {
            font-weight: 600;
            font-size: 14px;
        }
        .list-item-desc {
            font-size: 12px;
            color: var(--text-sub);
        }

        /* スライダー */
        .slider-wrapper {
            margin: 16px 0;
        }
        .slider-label-row {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 8px;
        }
        .thick-slider-container {
            position: relative;
            width: 100%;
            height: var(--ptz-slider-height);
            background: var(--bg-secondary);
            border-radius: calc(var(--ptz-slider-height) / 2);
            overflow: hidden;
            cursor: pointer;
            transition: height var(--transition-smooth);
        }
        .thick-slider-fill {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 50%;
            background: var(--accent-primary);
            transition: background-color var(--transition-smooth), width 0.1s ease-out;
        }
        .thick-slider-input {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
            margin: 0;
        }

        /* トグル */
        .toggle-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 4px;
        }
        .switch {
            position: relative;
            display: inline-block;
            width: var(--ptz-toggle-width);
            height: var(--ptz-toggle-height);
            transition: width var(--transition-smooth), height var(--transition-smooth);
        }
        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background: var(--bg-secondary);
            transition: var(--transition-smooth);
            border-radius: calc(var(--ptz-toggle-height) / 2);
        }
        .slider:before {
            position: absolute;
            content: "";
            height: var(--ptz-toggle-knob-width);
            width: var(--ptz-toggle-knob-width);
            left: 4px;
            bottom: calc((var(--ptz-toggle-height) - var(--ptz-toggle-knob-width)) / 2);
            background: white;
            transition: var(--transition-smooth);
            border-radius: var(--ptz-toggle-knob-radius);
        }
        input:checked + .slider {
            background: var(--accent-primary);
        }
        input:checked + .slider:before {
            transform: translateX(calc(var(--ptz-toggle-width) - var(--ptz-toggle-knob-width) - 8px));
        }

        /* ボタン */
        .ai-btn {
            border: none;
            outline: none;
            padding: 12px 24px;
            border-radius: 14px;
            font-weight: 600;
            font-size: 14px;
            color: white;
            cursor: pointer;
            background: var(--accent-primary);
            transition: transform 0.2s, background-color var(--transition-smooth);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            justify-content: center;
        }
        .ai-btn:hover {
            transform: scale(1.02);
        }
        .ai-btn:active {
            background: var(--accent-active);
            transform: scale(0.96);
        }
        .ai-btn-secondary {
            background: var(--bg-secondary);
            color: var(--text-main);
        }

        /* インプット */
        .glass-input-wrapper {
            margin-bottom: 14px;
        }
        .glass-input {
            width: 100%;
            padding: 12px 16px;
            border-radius: 12px;
            border: none;
            background: var(--bg-secondary);
            color: var(--text-main);
            font-size: 14px;
            font-family: inherit;
            box-sizing: border-box;
            transition: background var(--transition-smooth);
        }
        .glass-input:focus {
            outline: 2px solid var(--accent-primary);
        }

        /* ナビゲーションバー */
        .bottom-nav-container {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 72px;
            background: var(--nav-bg);
            border-top: 1px solid var(--bg-secondary);
            z-index: 500;
            display: flex;
            justify-content: space-around;
            align-items: center;
            padding-bottom: env(safe-area-inset-bottom);
            transition: background-color var(--transition-smooth), border-color var(--transition-smooth);
        }
        .nav-item {
            flex: 1;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-sub);
            transition: color 0.25s var(--m3-easing);
            position: relative;
            gap: 4px;
        }
        .nav-item span.material-symbols-outlined {
            font-size: 24px;
            font-variation-settings: 'FILL' 0, 'wght' 400;
            transition: font-variation-settings 0.2s, color 0.2s;
        }
        .nav-label {
            font-size: 10px;
            font-weight: 600;
        }
        .nav-item.active {
            color: var(--nav-icon-active);
        }
        .nav-item.active span.material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 700;
        }

        /* ビュー切り替え */
        .view {
            display: none;
        }
        .view.active {
            display: block;
            animation: viewIn 0.3s var(--m3-easing);
        }
        @keyframes viewIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* PTZ関連 */
        .ptz-dropzone {
            border: 2px dashed var(--text-sub);
            border-radius: var(--ptz-card-radius);
            padding: 24px;
            text-align: center;
            cursor: pointer;
            background: rgba(0, 0, 0, 0.02);
            transition: background 0.2s, border-color 0.2s;
            margin-bottom: 16px;
        }
        .dark-mode .ptz-dropzone {
            background: rgba(255, 255, 255, 0.02);
        }
        .ptz-dropzone:hover {
            background: rgba(51, 129, 255, 0.05);
            border-color: var(--accent-primary);
        }
        .json-textarea {
            width: 100%;
            height: 220px;
            font-family: monospace;
            font-size: 12.5px;
            padding: 16px;
            background: var(--bg-secondary);
            color: var(--text-main);
            border: none;
            border-radius: var(--ptz-card-radius);
            resize: vertical;
            outline: none;
            line-height: 1.4;
            transition: background var(--transition-smooth);
        }
        .preset-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            gap: 10px;
            margin-top: 10px;
        }
        .preset-btn {
            background: var(--bg-secondary);
            color: var(--text-main);
            border: none;
            padding: 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            text-align: center;
            transition: background 0.2s, transform 0.1s;
        }

        /* フランスボール顔出しキャラクタースタイル */
        #franceball-character {
            position: fixed;
            bottom: 72px; /* ナビバーのすぐ上 */
            right: -15px;
            width: 90px;
            height: 90px;
            z-index: 490;
            cursor: pointer;
            transition: transform 0.4s var(--m3-easing);
            display: flex;
            align-items: flex-end;
            justify-content: flex-end;
        }
        #franceball-character:hover {
            transform: translate(-10px, -5px) rotate(-5deg);
        }
        #franceball-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            pointer-events: auto;
        }
        /* フキダシ */
        #franceball-bubble {
            position: fixed;
            bottom: 160px;
            right: 20px;
            background: var(--glass-bg);
            color: var(--text-main);
            border-radius: 18px;
            padding: 14px 18px;
            width: 220px;
            font-size: 12px;
            line-height: 1.5;
            box-shadow: 0 8px 32px rgba(0,0,0,0.12);
            z-index: 600;
            display: none;
            animation: popBubble 0.3s var(--m3-easing);
            border: 1px solid var(--bg-secondary);
        }
        @keyframes popBubble {
            from { opacity: 0; transform: scale(0.9) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        /* メディアプレイヤーUIの追加スタイル */
        .player-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
        }
        .player-thumbnail-box {
            width: 80px;
            height: 80px;
            border-radius: 16px;
            background: var(--bg-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }
        .player-thumbnail-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .player-info {
            flex-grow: 1;
        }
        .player-info-title {
            font-weight: 700;
            font-size: 16px;
            margin-bottom: 4px;
            color: var(--text-main);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            max-width: 220px;
        }
        .player-info-status {
            font-size: 11px;
            color: var(--accent-primary);
            font-weight: 600;
        }
        .player-controls {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 24px;
            margin: 20px 0;
        }
        .ctrl-btn {
            background: none;
            border: none;
            color: var(--text-main);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: color 0.2s, transform 0.1s;
        }
        .ctrl-btn:active {
            transform: scale(0.9);
        }
        .ctrl-btn span {
            font-size: 32px;
        }
        .ctrl-btn.play-pause span {
            font-size: 56px;
            color: var(--accent-primary);
        }
        .search-box-container {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
        }

        /* ------------------ トースト通知 ------------------ */
        .toast {
            position: fixed;
            bottom: 84px;
            left: 50%;
            transform: translateX(-50%) translateY(20px);
            background: var(--text-main);
            color: var(--glass-bg);
            padding: 10px 20px;
            border-radius: 12px;
            font-size: 13px;
            font-weight: 600;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s var(--m3-easing);
            z-index: 2000;
        }
        .toast.active {
            opacity: 1;
            visibility: visible;
            transform: translateX(-50%) translateY(0);
        }

        /* ------------------ ダイアログ ------------------ */
        .dialog-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1000; display: flex; align-items: center; justify-content: center;
            opacity: 0; visibility: hidden; transition: all 0.3s var(--m3-easing);
        }
        .dialog-overlay.active { opacity: 1; visibility: visible; }
        .glass-dialog {
            background: var(--glass-bg);
            border-radius: var(--ptz-card-radius);
            padding: 24px; max-width: 380px; width: 90%; text-align: center;
            transform: scale(0.9) translateY(20px); transition: all 0.4s var(--m3-easing);
        }
        .dialog-overlay.active .glass-dialog { transform: scale(1) translateY(0); }

        .badge {
            background: var(--accent-primary);
            color: white;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
            display: inline-block;
        }

        /* クリップボード等のコンポーネント */
        .share-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--bg-secondary);
            border-radius: 12px;
            padding: 12px;
            margin-top: 10px;
        }
        .share-code {
            font-family: monospace;
            font-weight: 700;
            font-size: 16px;
            color: var(--accent-primary);
        }

        /* サムネイルプレビュー選択用 */
        .thumb-select-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            margin-top: 8px;
        }
        .thumb-select-item {
            aspect-ratio: 1;
            border-radius: 8px;
            background: var(--bg-secondary);
            cursor: pointer;
            overflow: hidden;
            border: 2px solid transparent;
        }
        .thumb-select-item.active {
            border-color: var(--accent-primary);
        }
        .thumb-select-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
    </style>
</head>
<body>

    <div id="app-viewport">
        <!-- ヘッダー -->
        <header>
            <div class="logo">
                <img src="https://raw.githubusercontent.com/PolandBallHub-Operator/pbimagesPublic/refs/heads/main/balls/france/lol.png" alt="FranceBall">
                <span>BG Movie Player</span>
            </div>
            <button class="theme-toggle" id="theme-btn" title="テーマ切り替え">
                <span class="material-symbols-outlined">light_mode</span>
            </button>
        </header>

        <!-- メインコンテンツ -->
        <main>
            <!-- 1. ホームビュー -->
            <section id="view-home" class="view active">
                <div class="glass-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                        <span class="badge" id="current-theme-badge">Engine Online</span>
                        <span style="font-size: 11px; color: var(--text-sub);">バックグラウンド高音質再生</span>
                    </div>
                    <h2>動画からバックグラウンド音声生成</h2>
                    <p>
                        動画ファイルをアップロード、または動画のウェブ直リンクURLを入力するだけで、無理やり「音声ファイル（mp3扱い）」として変換ロード。バックグラウンドやロック画面でも音が止まることなく楽しめます！
                    </p>

                    <!-- ファイルインポート部 -->
                    <div class="ptz-dropzone" onclick="triggerVideoFileInput()">
                        <span class="material-symbols-outlined" style="font-size: 40px; color: var(--accent-primary); margin-bottom: 8px;">video_file</span>
                        <div style="font-weight: 700; font-size: 14px;">ここに動画ファイルをドロップ、またはクリック</div>
                        <div style="font-size: 12px; color: var(--text-sub); margin-top: 4px;">端末内の動画を音声としてローカル保存します</div>
                        <input type="file" id="video-file-input" accept="video/*" style="display: none;" onchange="handleVideoFileSelect(event)">
                    </div>

                    <!-- URLから登録 -->
                    <div class="glass-input-wrapper">
                        <label style="font-size: 12px; font-weight: 700; display: block; margin-bottom: 6px;">ウェブ上の動画URLを入力</label>
                        <div style="display: flex; gap: 8px;">
                            <input type="text" id="video-url-input" class="glass-input" placeholder="https://example.com/video.mp4" style="margin-bottom:0;">
                            <button class="ai-btn" onclick="addVideoFromUrl()" style="flex-shrink:0;">
                                <span class="material-symbols-outlined">add</span>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="glass-card">
                    <h2>動画共有ツール</h2>
                    <p>他のユーザーと動画リンク、またはプリセット構成を共有するための簡易共有コードを生成できます。</p>
                    <div class="glass-input-wrapper">
                        <div style="display: flex; gap: 8px;">
                            <input type="text" id="share-code-input" class="glass-input" placeholder="共有コードを入力して読込..." style="margin-bottom:0;">
                            <button class="ai-btn" onclick="loadSharedVideo()">読み込む</button>
                        </div>
                    </div>

                    <!-- 生成された共有コード表示領域 -->
                    <div id="share-display-area" style="display:none;">
                        <div class="share-item">
                            <div>
                                <div style="font-size:11px; color:var(--text-sub);">共有コード</div>
                                <div class="share-code" id="generated-share-code">XXXXXX</div>
                            </div>
                            <button class="preset-btn" onclick="copyShareCode()" style="margin:0; padding:6px 12px;">コピー</button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 2. 保存・プレイヤービュー (元 view-components) -->
            <section id="view-components" class="view">
                <!-- メディアプレイヤー（音声扱いのシークなど） -->
                <div class="glass-card">
                    <div class="player-header">
                        <div class="player-thumbnail-box" onclick="openThumbnailDialog()">
                            <img id="player-thumb-img" src="https://placehold.co/150x150/3381FF/ffffff?text=FranceBall" alt="Thumbnail">
                            <div style="position: absolute; bottom: 0; width: 100%; background: rgba(0,0,0,0.5); color: #fff; font-size: 8px; text-align: center; padding: 2px 0;">サムネ変更</div>
                        </div>
                        <div class="player-info">
                            <div class="player-info-title" id="player-title">未再生</div>
                            <div class="player-info-status" id="player-status">再生リストから曲を選択してください</div>
                        </div>
                    </div>

                    <!-- 進行シークバー (太いスライダーをシーク用に活用) -->
                    <div class="slider-wrapper">
                        <div class="slider-label-row">
                            <span id="player-time-current">0:00</span>
                            <span id="player-time-duration">0:00</span>
                        </div>
                        <div class="thick-slider-container" id="progress-container">
                            <div class="thick-slider-fill" id="progress-fill" style="width: 0%;"></div>
                            <input type="range" class="thick-slider-input" id="player-progress" min="0" max="100" value="0" oninput="seekPlayer(this.value)">
                        </div>
                    </div>

                    <!-- プレイヤー操作ボタン -->
                    <div class="player-controls">
