    <!-- Firebase configuration & Firestore imports -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc, collection, getDocs } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Firebaseの連携準備
        let db = null;
        let auth = null;
        let userId = null;
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'franceball-bg-player';

        async function initFirebase() {
            if (typeof __firebase_config !== 'undefined') {
                try {
                    const firebaseConfig = JSON.parse(__firebase_config);
                    const app = initializeApp(firebaseConfig);
                    db = getFirestore(app);
                    auth = getAuth(app);

                    // Auth Before Queries
                    if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                        await signInWithCustomToken(auth, __initial_auth_token);
                    } else {
                        await signInAnonymously(auth);
                    }
                    userId = auth.currentUser?.uid || crypto.randomUUID();
                    console.log("Firebase initialized. User ID:", userId);
                } catch (e) {
                    console.error("Firebase init failed:", e);
                }
            }
        }

        window.firebaseShareVideo = async function(title, videoUrl) {
            if (!db || !userId) {
                showToast("クラウド機能が有効ではありません(ローカルのみ対応中)");
                return null;
            }
            try {
                // RULE 1: Strict Paths
                const shareId = "share-" + Math.floor(100000 + Math.random() * 900000);
                const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'shares', shareId);
                await setDoc(docRef, {
                    shareId: shareId,
                    title: title,
                    videoUrl: videoUrl,
                    userId: userId,
                    createdAt: Date.now()
                });
                return shareId;
            } catch (error) {
                console.error("Error writing to Firestore:", error);
                return null;
            }
        };

        window.firebaseLoadSharedVideo = async function(shareId) {
            if (!db) {
                showToast("クラウド機能が有効ではありません");
                return null;
            }
            try {
                // RULE 1 & 2: Simple query
                const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'shares', shareId);
                const docSnap = await getDoc(docRef);
                if (docSnap.exists()) {
                    return docSnap.data();
                } else {
                    return null;
                }
            } catch (error) {
                console.error("Error reading from Firestore:", error);
                return null;
            }
        };

        // DOMの準備が整い次第Firebase初期化
        window.addEventListener('DOMContentLoaded', () => {
            initFirebase();
        });
    </script>

