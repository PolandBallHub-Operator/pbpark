                thumbnail: "https://raw.githubusercontent.com/PolandBallHub-Operator/pbimagesPublic/refs/heads/main/balls/france/lol.png", // デフォルトでフランスボール
                addedAt: Date.now()
            };

            const tx = dbInstance.transaction('videos', 'readwrite');
            const store = tx.objectStore('videos');
            store.add(videoData);

            tx.oncomplete = function() {
                showToast("保存完了！『保存・再生』タブを確認するんね！");
                loadVideosFromDB();
            };
            tx.onerror = function(e) {
                showToast("エラー：容量制限に達した可能性があります。");
