        // ウェブ上の動画URLを登録
        function addVideoFromUrl() {
            const urlInput = document.getElementById('video-url-input');
            const url = urlInput.value.trim();
            if (!url) {
                showToast("URLを入力してください");
                return;
            }

            // タイトルを推測
            let title = "Webビデオ " + new Date().toLocaleTimeString();
            try {
                const parsedUrl = new URL(url);
                const pathParts = parsedUrl.pathname.split('/');
                const lastPart = pathParts[pathParts.length - 1];
                if (lastPart) title = decodeURIComponent(lastPart);
            } catch(e) {}

            const videoData = {
                title: title,
                url: url, // 外部URL
                thumbnail: "https://placehold.co/150x150/3381FF/ffffff?text=Web+Video",
                addedAt: Date.now()
            };

            const tx = dbInstance.transaction('videos', 'readwrite');
            const store = tx.objectStore('videos');
            store.add(videoData);

            tx.oncomplete = function() {
                showToast("Webビデオ保存完了！");
                urlInput.value = "";
                loadVideosFromDB();
            };
        }

        // Firebase共有コード発行
        async function loadVideosFromDB() {
            if (!dbInstance) return;
            const tx = dbInstance.transaction('videos', 'readonly');
            const store = tx.objectStore('videos');
            const request = store.getAll();

            request.onsuccess = function(e) {
                playlist = e.target.result;
                renderVideoList();
            };
        }

        // リスト表示
