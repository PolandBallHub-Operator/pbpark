                    </div>
                    <div style="display:flex; gap: 8px; align-items:center;">
                        <button class="preset-btn" style="margin:0; padding:6px; background:none; color:var(--accent-primary);" onclick="generateShareCode(${originalIndex})" title="共有コードを作成">
                            <span class="material-symbols-outlined" style="font-size:20px;">share</span>
                        </button>
                    </div>
                `;
                listContainer.appendChild(item);
            });
        }

        // --- バックグラウンド・音声化再生コアロジック ---
        let objectUrlToRevoke = null;

        function playTrack(index) {
            if (index < 0 || index >= playlist.length) return;
            currentIndex = index;
            const track = playlist[index];

            // プレイヤー表示の更新
            document.getElementById('player-title').textContent = track.title;
            document.getElementById('player-status').textContent = track.blob ? "ローカルソース音声変換再生中" : "Webストリーミング再生中";
            document.getElementById('player-thumb-img').src = track.thumbnail;

            // 以前のObjectURLを解放してメモリリークを防ぐ
            if (objectUrlToRevoke) {
                URL.revokeObjectURL(objectUrlToRevoke);
                objectUrlToRevoke = null;
            }

            // 無理やり音声ファイル扱いで再生
            if (track.blob) {
                // BlobからオブジェクトURLを作成し、オーディオ要素にセット！
                objectUrlToRevoke = URL.createObjectURL(track.blob);
                hiddenAudio.src = objectUrlToRevoke;
            } else if (track.url) {
                hiddenAudio.src = track.url;
            }

            hiddenAudio.load();
            hiddenAudio.play()
                .then(() => {
                    updatePlayPauseUI(true);
                    showToast(`「${track.title}」をバックグラウンド音声モードで再生中`);
                })
                .catch(e => {
                    console.error("Playback failed:", e);
                    showToast("再生に失敗しました。ファイル形式またはブラウザの制限を確認してください。");
                });

            // メディアセッションを設定（ロック画面用表示など）
            if ('mediaSession' in navigator) {
                navigator.mediaSession.metadata = new MediaMetadata({
                    title: track.title,
                    artist: "FranceBall BG Engine",
                    album: "バックグラウンド動画ハブ",
                    artwork: [
                        { src: track.thumbnail, sizes: '256x256', type: 'image/png' }
                    ]
                });

                navigator.mediaSession.setActionHandler('play', () => hiddenAudio.play());
                navigator.mediaSession.setActionHandler('pause', () => hiddenAudio.pause());
                navigator.mediaSession.setActionHandler('previoustrack', () => prevTrack());
                navigator.mediaSession.setActionHandler('nexttrack', () => nextTrack());
            }

            switchView('view-components');
        }

        function togglePlayPause() {
            if (currentIndex === -1) {
                if (playlist.length > 0) {
                    playTrack(0);
                } else {
                    showToast("再生するビデオがありません。追加してください。");
                }
                return;
            }

            if (hiddenAudio.paused) {
                hiddenAudio.play();
                updatePlayPauseUI(true);
            } else {
                hiddenAudio.pause();
                updatePlayPauseUI(false);
            }
        }

        function updatePlayPauseUI(isPlaying) {
            const icon = playPauseBtn.querySelector('span');
            if (isPlaying) {
                icon.textContent = 'pause_circle';
            } else {
                icon.textContent = 'play_circle';
            }
        }

        function setVolume(val) {
            hiddenAudio.volume = val / 100;
        }

        // シーク処理
        function seekPlayer(percent) {
            if (!hiddenAudio.duration) return;
            const time = (percent / 100) * hiddenAudio.duration;
            hiddenAudio.currentTime = time;
        }

        // 進捗の定期更新
        hiddenAudio.addEventListener('timeupdate', () => {
            if (!hiddenAudio.duration) return;
            
            const current = hiddenAudio.currentTime;
            const duration = hiddenAudio.duration;
            const percent = (current / duration) * 100;

            document.getElementById('progress-fill').style.width = `${percent}%`;
            document.getElementById('player-progress').value = percent;

            document.getElementById('player-time-current').textContent = formatTime(current);
            document.getElementById('player-time-duration').textContent = formatTime(duration);
        });

        hiddenAudio.addEventListener('ended', () => {
            if (isLooping) {
                hiddenAudio.currentTime = 0;
                hiddenAudio.play();
            } else {
                nextTrack();
            }
        });

        function toggleLoop() {
            isLooping = !isLooping;
            const icon = document.getElementById('loop-icon');
            if (isLooping) {
                icon.style.color = "var(--accent-primary)";
                showToast("1曲ループON");
            } else {
                icon.style.color = "var(--text-sub)";
                showToast("ループOFF");
            }
        }

        function prevTrack() {
            if (playlist.length === 0) return;
            let index = currentIndex - 1;
            if (index < 0) index = playlist.length - 1;
            playTrack(index);
        }

        function nextTrack() {
            if (playlist.length === 0) return;
            let index = currentIndex + 1;
            if (index >= playlist.length) index = 0;
            playTrack(index);
        }

        // 現在再生中のトラックをIndexedDBから削除
        function deleteCurrentTrack() {
            if (currentIndex === -1) return;
            const track = playlist[currentIndex];
            if (!confirm(`「${track.title}」を削除してもよろしいですか？`)) return;

            const tx = dbInstance.transaction('videos', 'readwrite');
            const store = tx.objectStore('videos');
            store.delete(track.id);

            tx.oncomplete = function() {
                showToast("削除が完了しました");
                currentIndex = -1;
                document.getElementById('player-title').textContent = "未再生";
                document.getElementById('player-status').textContent = "再生リストから曲を選択してください";
                hiddenAudio.src = "";
                updatePlayPauseUI(false);
                loadVideosFromDB();
            };
        }

        function formatTime(seconds) {
            if (isNaN(seconds)) return "0:00";
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins}:${secs < 10 ? '0' : ''}${secs}`;
        }

        function escapeHTML(str) {
            return str.replace(/[&<>'"]/g, 
                tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
            );
        }

        // --- 共有コードの送信・読み込み ---
        async function generateShareCode(index) {
            const track = playlist[index];
            if (!track.url) {
                showToast("ローカルに保存されたファイルは、メタデータの都合上リンクでの共有ができません。エクスポート機能をご活用ください。Webリンク動画は共有可能です！");
                return;
            }

            showToast("共有コードを生成中...");
            if (window.firebaseShareVideo) {
                const code = await window.firebaseShareVideo(track.title, track.url);
                if (code) {
                    document.getElementById('share-display-area').style.display = 'block';
                    document.getElementById('generated-share-code').textContent = code;
                    switchView('view-home');
                } else {
                    showToast("共有コードの生成に失敗しました");
                }
            } else {
                showToast("クラウド機能がまだ利用可能になっていません。");
            }
        }

        function copyShareCode() {
            const code = document.getElementById('generated-share-code').textContent;
            const dummy = document.createElement("textarea");
            document.body.appendChild(dummy);
            dummy.value = code;
            dummy.select();
            document.execCommand('copy');
            document.body.removeChild(dummy);
            showToast("共有コードをコピーしました！他のユーザーに教えてあげてください。");
        }

        async function loadSharedVideo() {
            const codeInput = document.getElementById('share-code-input');
            const code = codeInput.value.trim();
            if (!code) {
                showToast("共有コードを入力してください");
                return;
            }

            showToast("共有コードから動画をロード中...");
            if (window.firebaseLoadSharedVideo) {
                const data = await window.firebaseLoadSharedVideo(code);
                if (data) {
                    // IndexedDBへ登録
                    const videoData = {
                        title: "[共有] " + data.title,
                        url: data.videoUrl,
                        thumbnail: "https://placehold.co/150x150/FF3B30/ffffff?text=Shared+Video",
                        addedAt: Date.now()
                    };

                    const tx = dbInstance.transaction('videos', 'readwrite');
                    const store = tx.objectStore('videos');
                    store.add(videoData);

                    tx.oncomplete = function() {
                        showToast("動画リンクをインポートしました！『保存・再生』タブへどうぞ！");
                        codeInput.value = "";
                        loadVideosFromDB();
                    };
                } else {
                    showToast("共有コードが見つかりません");
                }
            } else {
                showToast("クラウドサービスに接続されていません。");
            }
        }

        // --- サムネイル変更システム ---
        function openThumbnailDialog() {
            if (currentIndex === -1) {
                showToast("先に再生リストから曲を選択してください");
                return;
            }
            document.getElementById('thumbnail-dialog').classList.add('active');
        }
        function closeThumbnailDialog() {
            document.getElementById('thumbnail-dialog').classList.remove('active');
        }
        function triggerThumbFileInput() {
            document.getElementById('thumb-file-input').click();
        }

        function handleThumbFileSelect(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                updateCurrentTrackThumbnail(e.target.result);
                closeThumbnailDialog();
            };
            reader.readAsDataURL(file);
        }

        function selectPresetThumb(type) {
            let url = "";
            if (type === 'france') {
                url = "https://raw.githubusercontent.com/PolandBallHub-Operator/pbimagesPublic/refs/heads/main/balls/france/lol.png";
            } else if (type === 'default') {
                url = "https://placehold.co/150x150/3381FF/ffffff?text=Video";
            } else if (type === 'red') {
                url = "https://placehold.co/150x150/FF3B30/ffffff?text=Audio";
            } else if (type === 'sunset') {
                url = "https://placehold.co/150x150/FF9500/ffffff?text=Sunset";
            }
            updateCurrentTrackThumbnail(url);
            closeThumbnailDialog();
        }

        function updateCurrentTrackThumbnail(thumbnailUrl) {
            if (currentIndex === -1) return;
            const track = playlist[currentIndex];
            
            const tx = dbInstance.transaction('videos', 'readwrite');
            const store = tx.objectStore('videos');
            
            track.thumbnail = thumbnailUrl;
            store.put(track);

            tx.oncomplete = function() {
                showToast("サムネイルを変更しました");
                document.getElementById('player-thumb-img').src = thumbnailUrl;
                loadVideosFromDB();
            };
        }

        // --- 従来のPTZ.jsonインポート/エクスポート対応 ---
        function triggerFileInput() {
            document.getElementById('ptz-file-input').click();
        }

        function handleFileSelect(event) {
            const file = event.target.files[0];
            if (!file) return;
            readFile(file);
        }

        function readFile(file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const text = e.target.result;
                if (validateAndApplyJson(text)) {
                    showToast(`${file.name} を正しく適用しました！`);
                } else {
                    showToast('読み込んだJSONファイルにエラーがあります');
                }
            };
            reader.readAsText(file);
        }

        function validateAndApplyJson(textVal) {
            try {
                const parsed = JSON.parse(textVal);
                jsonErrorMsg.style.display = 'none';
                applyPtz(parsed);
                return true;
            } catch (e) {
                jsonErrorMsg.textContent = `JSON構文エラー: ${e.message}`;
                jsonErrorMsg.style.display = 'block';
                return false;
            }
        }

        function applyJsonFromTextArea() {
            if (validateAndApplyJson(ptzCodeArea.value)) {
                showToast('PTZ.json 変更が手動適用されました');
            } else {
                showToast('エラー箇所を修正してください');
            }
        }

        function loadPreset(key) {
            if (presets[key]) {
                applyPtz(presets[key]);
                showToast(`プリセット [${presets[key].themeName}] をロードしました`);
            }
        }

        function copyJsonToClipboard() {
            ptzCodeArea.select();
            document.execCommand('copy');
            showToast('PTZ.json をクリップボードにコピーしました！');
        }

        function downloadJsonFile() {
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(ptzCodeArea.value);
            const downloadAnchor = document.createElement('a');
            downloadAnchor.setAttribute("href", dataStr);
            downloadAnchor.setAttribute("download", `${currentPtz.themeName.toLowerCase().replace(/\s+/g, '_')}.json`);
            document.body.appendChild(downloadAnchor);
            downloadAnchor.click();
            downloadAnchor.remove();
            showToast('PTZ.json ファイルのダウンロードを開始しました');
        }

        // --- 太いブルースライダー用の同期関数 ---
        function updateThickSlider(fillId, labelId, val, unit) {
            const label = document.getElementById(labelId);
            const fill = document.getElementById(fillId);
            if (label) label.textContent = `${val}${unit}`;
            if (fill) {
                const input = fill.nextElementSibling;
                if (input) {
                    const min = parseFloat(input.min) || 0;
                    const max = parseFloat(input.max) || 100;
                    const percent = ((val - min) / (max - min)) * 100;
                    fill.style.width = `${percent}%`;
                }
            }
        }

        // --- ビュー切り替え機構 ---
        const navItems = document.querySelectorAll('.nav-item');
        const views = document.querySelectorAll('.view');

        function switchView(viewId) {
            navItems.forEach(n => {
                n.classList.remove('active');
                if (n.getAttribute('data-view') === viewId) {
                    n.classList.add('active');
                }
            });

            views.forEach(v => {
                v.classList.remove('active');
                if (v.id === viewId) {
                    v.classList.add('active');
                }
            });
        }

        function openOverviewDialog() {
            document.getElementById('main-dialog').classList.add('active');
        }
        function closeDialog() {
            document.getElementById('main-dialog').classList.remove('active');
        }

        function showToast(msg) {
            toast.textContent = msg;
            toast.classList.add('active');
            setTimeout(() => {
                toast.classList.remove('active');
            }, 3000);
        }

        function setTheme(isDark) {
            document.body.classList.toggle('dark-mode', isDark);
            themeIcon.textContent = isDark ? 'dark_mode' : 'light_mode';
            const root = document.documentElement;
            root.style.setProperty('--bg-base', isDark ? currentPtz.bgDark : currentPtz.bgLight);
        }

        themeBtn.addEventListener('click', () => {
            setTheme(!document.body.classList.contains('dark-mode'));
        });

        // 触感ジェリー風バウンド演出
        document.addEventListener('mousedown', (e) => {
            const target = e.target.closest('.glass-card, .ai-btn, .nav-item, .preset-btn');
            if (target) {
                target.classList.remove('squish-active');
                void target.offsetWidth;
                target.classList.add('squish-active');
                setTimeout(() => {
                    target.classList.remove('squish-active');
                }, 350);
            }
        });

        // 初期ロード
        window.onload = async () => {
            await initIndexedDB();
            applyPtz(currentPtz);
            updateThickSlider('slider-vol-fill', 'val-vol', 100, '%');
            loadVideosFromDB();
        };
    </script>
</body>
</html>
